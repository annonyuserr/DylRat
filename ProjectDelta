-- ==========================================================
-- FUNCIÓN PARA ACTUALIZAR LA BARRA DE INVENTARIO
-- ==========================================================
local currentInvTarget = nil
local lastInvRefresh = 0

local function RefreshInventoryBar(targetPlayer)
    -- Limpiamos los ítems actuales
    for _, child in ipairs(InvBarContainer:GetChildren()) do
        if child:IsA("Frame") then child:Destroy() end
    end

    if not targetPlayer then return end
    local inv = targetPlayer:FindFirstChild("Inventory")
    if not inv then return end

    -- Rellenamos con lo nuevo
    for _, item in ipairs(inv:GetChildren()) do
        local hasItem = false
        if item:IsA("BoolValue") and item.Value == true then hasItem = true end
        if (item:IsA("IntValue") or item:IsA("NumberValue")) and item.Value > 0 then hasItem = true end

        if hasItem then
            local slot = Instance.new("Frame", InvBarContainer)
            slot.Size = UDim2.new(0, 60, 0, 25)
            slot.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
            slot.BorderSizePixel = 0
            AddOutline(slot)

            local lbl = Instance.new("TextLabel", slot)
            lbl.Size = UDim2.new(1, 0, 1, 0)
            lbl.BackgroundTransparency = 1
            lbl.TextColor3 = Color3.new(1, 1, 1)
            lbl.Font = Enum.Font.Code
            lbl.TextSize = 11
            
            -- Limpiamos el texto
            local cleanName = item.Name:gsub("Clothing", ""):gsub("Equipment", ""):gsub("Item", "")
            if (item:IsA("IntValue") or item:IsA("NumberValue")) and item.Value > 1 then
                cleanName = cleanName .. " x" .. item.Value
            end
            lbl.Text = cleanName
        end
    end
end

