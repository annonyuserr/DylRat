local activeOptionKey, activeColorSquare = nil, nil
local currentHue, currentSat, currentVal = 0, 1, 1

local function updateColorPickerOutput()
    local selectedColor = Color3.fromHSV(currentHue, currentSat, currentVal)
    SatValFrame.BackgroundColor3 = Color3.fromHSV(currentHue, 1, 1)
    if activeOptionKey and activeColorSquare then Options[activeOptionKey] = selectedColor; activeColorSquare.BackgroundColor3 = selectedColor end
end

local function trackSatVal(input)
    local mouseX = math.clamp((input.Position.X - SatValFrame.AbsolutePosition.X) / SatValFrame.AbsoluteSize.X, 0, 1)
    local mouseY = math.clamp((input.Position.Y - SatValFrame.AbsolutePosition.Y) / SatValFrame.AbsoluteSize.Y, 0, 1)
    currentSat, currentVal = mouseX, 1 - mouseY; PickerCircle.Position = UDim2.new(mouseX, 0, mouseY, 0); updateColorPickerOutput()
end

local function trackHue(input)
    local mouseY = math.clamp((input.Position.Y - HueFrame.AbsolutePosition.Y) / HueFrame.AbsoluteSize.Y, 0, 1)
    currentHue = mouseY; HueCircle.Position = UDim2.new(0.5, 0, mouseY, 0); updateColorPickerOutput()
end

local isDragSV, isDragH = false, false
SatValFrame.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then isDragSV = true; trackSatVal(input) end end)
HueFrame.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then isDragH = true; trackHue(input) end end)
UserInputService.InputChanged:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseMovement then if isDragSV then trackSatVal(input) elseif isDragH then trackHue(input) end end end)
UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then isDragSV = false; isDragH = false end end)

