            for k, v in pairs(Options) do if typeof(v) == "Color3" then configTable[k] = {v.R, v.G, v.B, "__isColor3"} else configTable[k] = v end end
            writefile("DylRatPD/" .. cfgName .. ".lua", HttpService:JSONEncode(configTable))
            if AutoLoadMark.Visible then writefile("DylRatPD/autoload.txt", cfgName) end
        end)
    end
end)

