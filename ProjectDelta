RunService.RenderStepped:Connect(function()
    local dynamicColor = GetColor("accent_color")
    for _, item in ipairs(AccentObjects) do pcall(function() item.Instance[item.Property] = dynamicColor end) end
    if ActiveTabButton then pcall(function() ActiveTabButton.TextColor3 = dynamicColor end) end
    for key, sq in pairs(ColorSquares) do pcall(function() sq.BackgroundColor3 = GetColor(key) end) end
    
    local Targets = {}
    for _, p in ipairs(Players:GetPlayers()) do if p ~= LocalPlayer and p.Character then table.insert(Targets, {Type = "Player", Char = p.Character, Obj = p}) end end
    for _, npc in ipairs(DetectedNPCs) do if npc and npc.Parent and npc:FindFirstChildOfClass("Humanoid") and npc:FindFirstChild("HumanoidRootPart") then table.insert(Targets, {Type = "NPC", Char = npc, Obj = npc}) end end
    
    for cachedObj, _ in pairs(ESP_Cache) do
        local isStillValid = false
        for _, t in ipairs(Targets) do if t.Obj == cachedObj then isStillValid = true; break end end
        if not isStillValid then CleanESP(cachedObj) end
    end
    
    for _, target in ipairs(Targets) do
        local isNpc = (target.Type == "NPC")
        local char = target.Char
        local hum = char:FindFirstChildOfClass("Humanoid")
        local hrp = char:FindFirstChild("HumanoidRootPart")
        local data = ESP_Cache[target.Obj] or CreateESP(target.Obj)
        
        if hum and hrp then
            local maxHp = char:GetAttribute("MaxHealth") or hum:GetAttribute("MaxHealth") or hum.MaxHealth or 100
            local curHp = char:GetAttribute("Health") or hum:GetAttribute("Health") or hum.Health or 0
            local factor = math.clamp(curHp / maxHp, 0, 1)
            local pos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
            
            -- LÓGICA DE CHAMS INDEPENDIENTE
            local optChams = if isNpc then Options.npc_chams else Options.chams
            if optChams and curHp > 0 then
                data.Chams.Adornee = char
                data.Chams.Enabled = true
                data.Chams.FillColor = GetColor(if isNpc then "npc_chams_color" else "chams_color")
                data.Chams.FillTransparency = if isNpc then Options.npc_chams_transparency else (Options.chams_transparency or 0.5)
            else
                data.Chams.Enabled = false
            end
            
            if onScreen and curHp > 0 then
                local sizeY = (Camera:WorldToViewportPoint(hrp.Position - Vector3.new(0, 3, 0)).Y - Camera:WorldToViewportPoint(hrp.Position + Vector3.new(0, 2.6, 0)).Y)
                local boxSize = Vector2.new(sizeY / 1.5, sizeY)
                local boxPos = Vector2.new(pos.X - boxSize.X / 2, pos.Y - boxSize.Y / 2)
                
                -- LÓGICA DE BOX 2D Y RELLENO
                local optBox = if isNpc then Options.npc_box else Options.box
                data.Box.Visible = optBox
                if optBox then 
                    data.Box.Size = UDim2.new(0, boxSize.X, 0, boxSize.Y)
                    data.Box.Position = UDim2.new(0, boxPos.X, 0, boxPos.Y)
                    data.BoxOutline.Color = GetColor(if isNpc then "npc_box_color" else "box_color")
                    
                    local optBoxFill = if isNpc then Options.npc_box_fill else Options.box_fill
                    if optBoxFill then
                        data.Box.BackgroundColor3 = GetColor(if isNpc then "npc_box_fill_color" else "box_fill_color")
                        data.Box.BackgroundTransparency = if isNpc then Options.npc_box_fill_transparency else (Options.box_fill_transparency or 0.5)
                    else
                        data.Box.BackgroundTransparency = 1
                    end
                end
                
                -- LÓGICA DE NAMETAG
                local optName = if isNpc then Options.npc_nametag else Options.nametag
                data.Name.Visible = optName
                if optName then 
                    data.Name.Text = if isNpc then "[BOT] " .. char.Name else target.Obj.Name
                    data.Name.Position = UDim2.new(0, boxPos.X, 0, boxPos.Y - 14)
                    data.Name.Size = UDim2.new(0, boxSize.X, 0, 12)
                    data.Name.TextSize = if isNpc then Options.npc_name_text_size else (Options.name_text_size or 12)
                    data.Name.TextColor3 = GetColor(if isNpc then "npc_nametag_color" else "nametag_color") 
                end
                
                -- LÓGICA DE HP BAR
                local optHpBar = if isNpc then Options.npc_hp_bar else Options.hp_bar
                data.HPBarBack.Visible = optHpBar
                if optHpBar then 
                    data.HPBarBack.Position = UDim2.new(0, boxPos.X - 6, 0, boxPos.Y)
                    data.HPBarBack.Size = UDim2.new(0, if isNpc then Options.npc_hp_bar_width else (Options.hp_bar_width or 2), 0, boxSize.Y)
                    data.HPBarFill.Visible = true
                    data.HPBarFill.BackgroundColor3 = Color3.fromRGB(255, 0, 0):Lerp(Color3.fromRGB(0, 255, 0), factor)
                    data.HPBarFill.Size = UDim2.new(1, 0, factor, 0)
                    data.HPBarFill.Position = UDim2.new(0, 0, 1 - factor, 0)
                else
                    data.HPBarFill.Visible = false
                end
                
                -- LÓGICA DE HP TEXT
                local optHpText = if isNpc then Options.npc_hp_text else Options.hp_text
                data.HPText.Visible = optHpText
                if optHpText then
                    data.HPText.Text = math.round(curHp) .. " HP"
                    data.HPText.Position = UDim2.new(0, boxPos.X + boxSize.X + 4, 0, boxPos.Y)
                    data.HPText.Size = UDim2.new(0, 50, 0, 12)
                    data.HPText.TextXAlignment = Enum.TextXAlignment.Left
                    data.HPText.TextColor3 = GetColor(if isNpc then "npc_hp_text_color" else "hp_text_color")
                end
                
                -- LÓGICA DE DISTANCIA
                local optDist = if isNpc then Options.npc_distance else Options.distance
                data.Dist.Visible = optDist
                if optDist then
                    local distance = math.round((Camera.CFrame.Position - hrp.Position).Magnitude)
                    data.Dist.Text = distance .. "m"
                    data.Dist.Position = UDim2.new(0, boxPos.X, 0, boxPos.Y + boxSize.Y + 2)
                    data.Dist.Size = UDim2.new(0, boxSize.X, 0, 12)
                    data.Dist.TextSize = if isNpc then Options.npc_distance_text_size else (Options.distance_text_size or 12)
                    data.Dist.TextColor3 = GetColor(if isNpc then "npc_distance_color" else "distance_color")
                end
                
                -- LÓGICA DE SKELETON
                local optSkeleton = if isNpc then Options.npc_skeleton else Options.skeleton
                if optSkeleton then
                    local rigType = hum.RigType.Name
                    local bonesTable = SkeletonBones[rigType]
                    if bonesTable then
                        local lineIndex = 1
                        for _, bonePair in ipairs(bonesTable) do
                            local part1 = char:FindFirstChild(bonePair[1])
                            local part2 = char:FindFirstChild(bonePair[2])
                            if part1 and part2 then
                                local pos1, vis1 = Camera:WorldToViewportPoint(part1.Position)
                                local pos2, vis2 = Camera:WorldToViewportPoint(part2.Position)
                                if vis1 or vis2 then
                                    local line = data.Lines[lineIndex]
                                    if not line then
                                        line = Instance.new("Frame", MasterESP); line.BorderSizePixel = 0; line.AnchorPoint = Vector2.new(0.5, 0.5); data.Lines[lineIndex] = line
                                    end
                                    line.Visible = true
                                    line.BackgroundColor3 = GetColor(if isNpc then "npc_skeleton_color" else "skeleton_color")
                                    local center = Vector2.new((pos1.X + pos2.X) / 2, (pos1.Y + pos2.Y) / 2)
                                    local dist = (Vector2.new(pos1.X, pos1.Y) - Vector2.new(pos2.X, pos2.Y)).Magnitude
                                    local angle = math.deg(math.atan2(pos2.Y - pos1.Y, pos2.X - pos1.X))
                                    line.Position = UDim2.new(0, center.X, 0, center.Y)
                                    line.Size = UDim2.new(0, dist, 0, 1)
                                    line.Rotation = angle
                                    lineIndex = lineIndex + 1
                                end
                            end
                        end
                        for i = lineIndex, #data.Lines do data.Lines[i].Visible = false end
                    end
                else
                    for _, line in ipairs(data.Lines) do line.Visible = false end
                end
            else
                for _, obj in pairs(data) do if typeof(obj) == "Instance" and obj:IsA("GuiObject") then obj.Visible = false end end
                for _, line in ipairs(data.Lines) do line.Visible = false end
            end
        end
    end
    
    -- ==========================================================
    -- LÓGICA DEL INVENTORY CHECKER BAR (Integrada aquí)
    -- ==========================================================
    if Options.inventory_bar then
        local mousePos = Vector2.new(Mouse.X, Mouse.Y)
        local closestTarget = nil
        local shortestDist = 150 -- Distancia máxima en píxeles
        
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                local pos, onScreen = Camera:WorldToViewportPoint(player.Character.HumanoidRootPart.Position)
                if onScreen then
                    local dist = (Vector2.new(pos.X, pos.Y) - mousePos).Magnitude
                    if dist < shortestDist then
                        shortestDist = dist
                        closestTarget = player
                    end
                end
            end
        end
        
        if closestTarget then
            local pos, _ = Camera:WorldToViewportPoint(closestTarget.Character.HumanoidRootPart.Position)
            TargetCircle.Position = UDim2.new(0, pos.X, 0, pos.Y)
            TargetCircle.Visible = true
            InvBarContainer.Visible = true
            
            -- Refrescar inventario si cambiamos de objetivo o cada 1 segundo (para actualizaciones en tiempo real)
            if currentInvTarget ~= closestTarget or (tick() - lastInvRefresh > 1) then
                currentInvTarget = closestTarget
                lastInvRefresh = tick()
                RefreshInventoryBar(closestTarget)
            end
        else
            TargetCircle.Visible = false
            InvBarContainer.Visible = false
            if currentInvTarget ~= nil then
                currentInvTarget = nil
                RefreshInventoryBar(nil)
            end
        end
    else
        TargetCircle.Visible = false
        InvBarContainer.Visible = false
        if currentInvTarget ~= nil then
            currentInvTarget = nil
            RefreshInventoryBar(nil)
        end
    end
end)

