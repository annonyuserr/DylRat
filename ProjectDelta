local function LoadConfigLogic(cfgName)
    local filePath = "DylRatPD/" .. cfgName .. ".lua"
    if isfile(filePath) then
        pcall(function()
            local content = readfile(filePath); local decoded = HttpService:JSONDecode(content)
            if decoded then
                for k, v in pairs(decoded) do
                    if type(v) == "table" and v[4] == "__isColor3" then Options[k] = Color3.new(v[1], v[2], v[3]) else Options[k] = v end
                end
                for _, refreshFunc in ipairs(UI_Refresh_Registry) do pcall(refreshFunc) end
            end
        end)
    end
end

