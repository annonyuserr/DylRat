local function OpenColorPicker(key, square)
    if ColorPickerFrame.Visible and activeOptionKey == key then ColorPickerFrame.Visible = false; return end
    activeOptionKey, activeColorSquare = key, square
    local cur = Options[key] or Color3.new(1,1,1); currentHue, currentSat, currentVal = cur:ToHSV()
    SatValFrame.BackgroundColor3 = Color3.fromHSV(currentHue, 1, 1)
    PickerCircle.Position = UDim2.new(currentSat, 0, 1 - currentVal, 0)
    HueCircle.Position = UDim2.new(0.5, 0, currentHue, 0)
    ColorPickerFrame.Position = UDim2.new(0, square.AbsolutePosition.X + 25, 0, square.AbsolutePosition.Y - 5)
    RgbMark.Visible = Options[key .. "_rgb"] or false
    ColorPickerFrame.Visible = true
end

