            if successZoom and input.KeyCode == allowedZoomKey then
                local cam = workspace.CurrentCamera
                if cam then
                    isZooming = true
                    originalFov = cam.FieldOfView
                    cam.FieldOfView = Options.zoom_fov
                end
            end
        end
    end
end)

