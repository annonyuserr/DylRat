local function CleanESP(target)
    if ESP_Cache[target] then
        for _, obj in pairs(ESP_Cache[target]) do
            if typeof(obj) == "Instance" then 
                pcall(function() obj:Destroy() end)
            elseif type(obj) == "table" then 
                for _, line in pairs(obj) do pcall(function() line:Destroy() end) end 
            end
        end
        ESP_Cache[target] = nil
    end
end
