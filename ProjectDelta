local function CreateSlider(parent, optionKey, text, currentVal, maxVal, posY, isFloat)
    local Wrapper = Instance.new("Frame", parent); Wrapper.BackgroundTransparency = 1; Wrapper.Size = UDim2.new(1, 0, 0, 30); Wrapper.Position = UDim2.new(0, 0, 0, posY)
    local Label = Instance.new("TextLabel", Wrapper); Label.BackgroundTransparency = 1; Label.Text = text; Label.TextColor3 = Colors.GrisTexto; Label.Font = Enum.Font.Code; Label.TextSize = 12; Label.TextXAlignment = Enum.TextXAlignment.Left; Label.Size = UDim2.new(1, 0, 0, 14)
    local Track = Instance.new("TextButton", Wrapper); Track.BackgroundColor3 = Colors.BotonCuerpo; Track.Size = UDim2.new(1, 0, 0, 8); Track.Position = UDim2.new(0, 0, 0, 16); Track.Text = ""; AddOutline(Track)
    local Fill = Instance.new("Frame", Track); Fill.BackgroundColor3 = Options.accent_color; Fill.BorderSizePixel = 0; Fill.Size = UDim2.new(Options[optionKey] / maxVal, 0, 1, 0)
    RegisterAccentObject(Fill, "BackgroundColor3")
    local ValueLabel = Instance.new("TextLabel", Wrapper); ValueLabel.BackgroundTransparency = 1; ValueLabel.Text = Options[optionKey] .. "/" .. maxVal; ValueLabel.TextColor3 = Colors.GrisTexto; ValueLabel.Font = Enum.Font.Code; ValueLabel.TextSize = 11; ValueLabel.TextXAlignment = Enum.TextXAlignment.Right; ValueLabel.Size = UDim2.new(1, 0, 0, 14)
    
    local function UpdateSlider(inputPosition)
        local relativeX = math.clamp((inputPosition - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
        local calculatedVal = relativeX * maxVal
        if not isFloat then calculatedVal = math.round(calculatedVal) else calculatedVal = tonumber(string.format("%.1f", calculatedVal)) end
        Options[optionKey] = calculatedVal; Fill.Size = UDim2.new(relativeX, 0, 1, 0); ValueLabel.Text = calculatedVal .. "/" .. maxVal
    end
    Track.MouseButton1Down:Connect(function()
        local mouse = LocalPlayer:GetMouse(); UpdateSlider(mouse.X)
        local move = mouse.Move:Connect(function() UpdateSlider(mouse.X) end)
        local endInput = UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then move:Disconnect() end end)
    end)

    table.insert(UI_Refresh_Registry, function()
        local val = Options[optionKey] or currentVal
        Fill.Size = UDim2.new(val / maxVal, 0, 1, 0)
        ValueLabel.Text = val .. "/" .. maxVal
    end)
end

